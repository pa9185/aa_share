# ── Convex ────────────────────────────────────────────────────────────────────
# Auto-set by `npx convex dev` – copy the value from your Convex dashboard
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# ── S3-compatible storage (s3.p.thme.cc) ─────────────────────────────────────
AWS_ENDPOINT_URL=https://s3.p.thme.cc
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
# Region is required by the SDK but ignored by most S3-compatible servers
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Set these on your Convex deployment too (used inside generateTest action):
#   npx convex env set AWS_ENDPOINT_URL      "https://s3.p.thme.cc"
#   npx convex env set AWS_ACCESS_KEY_ID     "your-access-key"
#   npx convex env set AWS_SECRET_ACCESS_KEY "your-secret-key"
#   npx convex env set AWS_REGION            "us-east-1"
#   npx convex env set AWS_S3_BUCKET         "your-bucket-name"

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Get a key at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# Change the model without touching any code – just update this env var
# Examples: google/gemini-flash-1.5 | anthropic/claude-3-haiku | openai/gpt-4o-mini
OPENROUTER_MODEL=google/gemini-flash-1.5

# Set on Convex too:
#   npx convex env set OPENROUTER_API_KEY "sk-or-..."
#   npx convex env set OPENROUTER_MODEL   "google/gemini-flash-1.5"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin panel secret – visit /admin?secret=<value>
ADMIN_SECRET=change-me-in-production
# Set on Convex too:
#   npx convex env set ADMIN_SECRET "change-me-in-production"
